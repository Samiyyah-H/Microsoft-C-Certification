/*
This application manages transactions at a store check-out line. The
check-out line has a cash register, and the register has a cash till
that is prepared with a number of bills each morning. The till includes
bills of four denominations: $1, $5, $10, and $20. The till is used
to provide the customer with change during the transaction. The item 
cost is a randomly generated number between 2 and 49. The customer 
offers payment based on an algorithm that determines a number of bills
in each denomination. 

Each day, the cash till is loaded at the start of the day. As transactions
occur, the cash till is managed in a method named MakeChange (customer 
payments go in and the change returned to the customer comes out). A 
separate "safety check" calculation that's used to verify the amount of
money in the till is performed in the "main program". This safety check
is used to ensure that logic in the MakeChange method is working as 
expected.
*/

string? readResult = null;
bool useTestData = true;

Console.Clear();

// The drawer array. Index 0 = $1 bills, Index 1 = $5 bills, Index 2 = $10 bills, Index 3 = $20 bills
int[] cashTill = new int[] { 0, 0, 0, 0 };
int registerCheckTillTotal = 0;

// registerDailyStartingCash: $1 x 50, $5 x 20, $10 x 10, $20 x 5 => ($350 total)
int[,] registerDailyStartingCash = new int[,] { { 1, 50 }, { 5, 20 }, { 10, 10 }, { 20, 5 } };

int[] testData = new int[] { 6, 10, 17, 20, 31, 36, 40, 41 };
int testCounter = 0;

// Stock the register drawer using our morning rule setup
LoadTillEachMorning(registerDailyStartingCash, cashTill);

// Simple math equation to sum up the starting cash value ($350)
registerCheckTillTotal = registerDailyStartingCash[0, 0] * registerDailyStartingCash[0, 1] + registerDailyStartingCash[1, 0] * registerDailyStartingCash[1, 1] + registerDailyStartingCash[2, 0] * registerDailyStartingCash[2, 1] + registerDailyStartingCash[3, 0] * registerDailyStartingCash[3, 1];

// Display the number of bills of each denomination currently in the till
LogTillStatus(cashTill);

// Display a message showing the amount of cash in the till
Console.WriteLine(TillAmountSummary(cashTill));

// Display the expected registerDailyStartingCash total
Console.WriteLine($"Expected till value: {registerCheckTillTotal}\n\r");

var valueGenerator = new Random((int)DateTime.Now.Ticks);

int transactions = 10;

if (useTestData)
{
    transactions = testData.Length;
}

while (transactions > 0)
{
    transactions -= 1;
    int itemCost = valueGenerator.Next(2, 20);

    if (useTestData)
    {
        itemCost = testData[testCounter];
        testCounter += 1;
    }

    // Customer's automatic brain deciding what bills to give us:
    int paymentOnes = itemCost % 2;                 // value is 1 when itemCost is odd, value is 0 when itemCost is even
    int paymentFives = (itemCost % 10 > 7) ? 1 : 0; // value is 1 when itemCost ends with 8 or 9, otherwise value is 0
    int paymentTens = (itemCost % 20 > 13) ? 1 : 0; // value is 1 when 13 < itemCost < 20 OR 33 < itemCost < 40, otherwise value is 0
    int paymentTwenties = (itemCost < 20) ? 1 : 2;  // value is 1 when itemCost < 20, otherwise value is 2

    // Display messages describing the current transaction
    Console.WriteLine($"Customer is making a ${itemCost} purchase");
    Console.WriteLine($"\t Using {paymentTwenties} twenty dollar bills");
    Console.WriteLine($"\t Using {paymentTens} ten dollar bills");
    Console.WriteLine($"\t Using {paymentFives} five dollar bills");
    Console.WriteLine($"\t Using {paymentOnes} one dollar bills");

    // ============================================================================
    // TRY-CATCH EXCEPTION HANDLING PATTERN
    // ============================================================================
    // We wrap MakeChange in a "try" block. If MakeChange "throws" an exception down below, 
    // the code stops immediately and jumps straight down to the "catch" block.
    try
    {
        // MakeChange manages the transaction and updates the till 
        MakeChange(itemCost, cashTill, paymentTwenties, paymentTens, paymentFives, paymentOnes);

        // If no exception was thrown, the transaction succeeded!
        Console.WriteLine($"Transaction successfully completed.");
        registerCheckTillTotal += itemCost; // Keep our main safety counter updated
    }
    catch (InvalidOperationException ex)
    {
        // If an exception happened inside MakeChange, we catch it here.
        // ex.Message contains the text we threw (like "Not enough cash")
        Console.ForegroundColor = ConsoleColor.Red;
        Console.WriteLine($"Transaction unsuccessful: {ex.Message}");
        Console.ResetColor();
    }

    Console.WriteLine(TillAmountSummary(cashTill));
    Console.WriteLine($"Expected till value: {registerCheckTillTotal}\n\r");
    Console.WriteLine();
}

Console.WriteLine("Press the Enter key to exit");
do
{
    readResult = Console.ReadLine();

} while (readResult == null);


// ============================================================================
// THE APPLICATION HELPER METHODS
// ============================================================================

// 1. Dumps the morning cash rules into our actual register drawer array
static void LoadTillEachMorning(int[,] sourceCash, int[] till)
{
    till[0] = sourceCash[0, 1]; // Set $1 bill count
    till[1] = sourceCash[1, 1]; // Set $5 bill count
    till[2] = sourceCash[2, 1]; // Set $10 bill count
    till[3] = sourceCash[3, 1]; // Set $20 bill count
}

// 2. The main business engine that handles cash math and updates the register
static void MakeChange(int cost, int[] till, int twenties, int tens, int fives, int ones)
{
    // Math out total cash handed over by customer
    int amountPaid = (twenties * 20) + (tens * 10) + (fives * 5) + ones;

    // ERROR CHECK 1: Did they give us enough money?
    if (amountPaid < cost)
    {
        // Throw an exception to tell the main program something went wrong!
        throw new InvalidOperationException("The customer did not provide enough cash.");
    }

    int changeNeeded = amountPaid - cost;

    // We make a temporary copy of our till drawer. 
    // Why? If we run out of bills halfway through making change, we don't want 
    // to leave the real drawer half-edited and messed up!
    int[] tempTill = (int[])till.Clone();

    // Step A: Put the customer's cash inside our temporary drawer
    tempTill[0] += ones;
    tempTill[1] += fives;
    tempTill[2] += tens;
    tempTill[3] += twenties;

    // Step B: Hand back change using largest bills possible
    // index 3 is $20s, index 2 is $10s, index 1 is $5s, index 0 is $1s
    while (changeNeeded >= 20 && tempTill[3] > 0)
    {
        changeNeeded -= 20;
        tempTill[3]--;
    }
    while (changeNeeded >= 10 && tempTill[2] > 0)
    {
        changeNeeded -= 10;
        tempTill[2]--;
    }
    while (changeNeeded >= 5 && tempTill[1] > 0)
    {
        changeNeeded -= 5;
        tempTill[1]--;
    }
    while (changeNeeded >= 1 && tempTill[0] > 0)
    {
        changeNeeded -= 1;
        tempTill[0]--;
    }

    // ERROR CHECK 2: Do we have the exact right bills to give exact change?
    if (changeNeeded > 0)
    {
        // If we still owe money but ran out of bills, throw an error.
        // This instantly stops the method and leaves the real 'till' array safe and untouched.
        throw new InvalidOperationException("The register does not have enough correct bills to make change.");
    }

    // Success! If we made it here without throwing, overwrite the real permanent till with our temp copies.
    Array.Copy(tempTill, till, till.Length);
}

// 3. Simple log printout showing exactly how many of each bill are in the drawer
static void LogTillStatus(int[] till)
{
    Console.WriteLine($"Bills in till -> [$1]: {till[0]} | [$5]: {till[1]} | [$10]: {till[2]} | [$20]: {till[3]}");
}

// 4. Calculates the numerical total of all cash currently sitting in the till
static string TillAmountSummary(int[] till)
{
    int total = (till[0] * 1) + (till[1] * 5) + (till[2] * 10) + (till[3] * 20);
    return $"The total cash in the till is: ${total}";
}
